{
  "name": "pdfmark",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:web": "turbo run dev --filter=@pdfmark/web",
    "dev:mobile": "turbo run start --filter=@pdfmark/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  },
  "devDependencies": {
    "next": "16.2.9",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
